body {
    background: #0b0f14;
    color: #00ff88;
    font-family: "Courier New", monospace;
    max-width: 1100px;
    margin: auto;
    padding: 30px;
    line-height: 1.7;
}

h1 {
    color: #ffffff;
}

a {
    color: #00ff88;
    text-decoration: none;
}

a:hover {
    text-decoration: underline;
}

hr {
    border: 0;
    border-top: 1px solid #1f2937;
    margin: 25px 0;
}

ul {
    list-style-type: square;
}

nav {
    margin-bottom: 30px;
    padding-bottom: 15px;
    border-bottom: 1px solid #1f2937;
}

nav a {
    margin-right: 20px;
}

.container {
    max-width: 1100px;
}
